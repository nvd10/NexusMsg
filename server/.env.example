# Environment Configuration
PORT=443
HTTP_PORT=80
JWT_SECRET=change-this-to-a-very-long-random-secret-key
ADMIN_API_KEY=admin-secret-key-change-this
NODE_ENV=production

# SSL Certificates (for HTTPS)
SSL_KEY_PATH=/etc/letsencrypt/live/nexusmsg.example.com/privkey.pem
SSL_CERT_PATH=/etc/letsencrypt/live/nexusmsg.example.com/fullchain.pem

# TURN Server (optional — enables relay for restrictive NATs)
# Use coturn or any RFC 5766 TURN server
# TURN_SERVER_HOST=turn.nexusmsg.example.com
# TURN_SERVER_PORT=3478
# TURN_SERVER_USERNAME=nexusmsg-user
# TURN_SERVER_CREDENTIAL=your-static-credential
# TURN_SERVER_SECRET=your-hmac-sha1-secret
